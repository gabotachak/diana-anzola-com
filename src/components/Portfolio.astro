---
import Layout from "../layouts/Layout.astro";
import { profile, experience, education, languages, skills, services, process, whatsappLink } from "../data/profile";

const nav = [
  { href: "#services", label: "Servicios" },
  { href: "#how-i-work", label: "Cómo Trabajo" },
  { href: "#experience", label: "Experiencia" },
  { href: "#contact", label: "Contacto" },
];

const heroWhatsapp = whatsappLink("Hola Diana, necesito asesoría legal.");
---

<Layout>
  <div class="bg-paper min-h-screen">

    <!-- Nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-sm" style="background: var(--nav-bg); border-bottom: 1px solid var(--border);">
      <div class="flex justify-between items-center px-4 md:px-8 py-4 max-w-5xl mx-auto">
        <a href="#top" class="font-serif text-base tracking-tight" style="font-family: var(--serif); color: var(--accent); font-weight: 600;">
          <span style="color: var(--gold);">●</span> Diana Anzola Tachak
        </a>
        <div class="flex gap-5 md:gap-7 items-center">
          {nav.map(item => (
            <a href={item.href} class="nav-link hidden sm:inline">{item.label}</a>
          ))}
          <a href="/cv-diana-anzola-tachak.pdf" target="_blank" class="nav-link hidden sm:inline">Hoja de Vida</a>
          <a href={profile.contact.whatsapp} target="_blank" class="btn-primary hidden sm:inline-flex" style="padding: 7px 16px; font-size: 11px;">
            WhatsApp
          </a>
          <button id="menu-toggle" class="sm:hidden flex flex-col gap-[4px] p-1" aria-label="Abrir menú">
            <span class="hamburger-bar"></span>
            <span class="hamburger-bar"></span>
            <span class="hamburger-bar"></span>
          </button>
        </div>
      </div>
      <div id="mobile-menu" class="sm:hidden hidden px-4 pb-4 flex flex-col gap-1 max-w-5xl mx-auto">
        {nav.map(item => (
          <a href={item.href} class="nav-link mobile-nav-link">{item.label}</a>
        ))}
        <a href="/cv-diana-anzola-tachak.pdf" target="_blank" class="nav-link mobile-nav-link">Hoja de Vida</a>
        <a href={profile.contact.whatsapp} target="_blank" class="nav-link mobile-nav-link" style="color: var(--accent);">WhatsApp</a>
      </div>
    </nav>

    <!-- Hero / Introducción -->
    <section id="top" class="relative max-w-5xl mx-auto px-4 md:px-8 pt-32 md:pt-40 pb-20">
      <div class="flex flex-col md:flex-row items-start gap-8 md:gap-12">
        <div class="monogram reveal" style="opacity:1; transform:none;">DA</div>

        <div class="flex-1">
          <div class="inline-flex items-center gap-2 text-[10px] tracking-[0.2em] uppercase mb-5 px-2.5 py-1 rounded-sm" style="color: var(--dim); border: 1px solid var(--border); background: var(--surface);">
            <span style="color: var(--gold);">●</span> +14 años de experiencia
          </div>

          <h1 class="text-3xl md:text-5xl font-semibold mb-3 leading-tight" style="font-family: var(--serif); color: var(--text); letter-spacing:-0.3px;">
            {profile.heroTitle}
          </h1>

          <p class="text-base md:text-lg mb-6" style="color: var(--accent); font-family: var(--serif); font-style: italic;">
            {profile.name} · {profile.role} · Bogotá
          </p>

          <p class="text-sm md:text-[15px] leading-relaxed mb-4 max-w-xl" style="color: var(--text-soft);">
            {profile.bioClient}
          </p>

          <p class="prompt-quote text-sm leading-relaxed mb-8 max-w-xl" style="color: var(--dim); font-family: var(--serif); font-style: italic;">
            {profile.quote}
          </p>

          <div class="flex flex-wrap gap-3 mb-8">
            <a href={heroWhatsapp} target="_blank" class="btn-primary">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.85 9.85 0 0 0 4.73 1.2h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm0 18.15h-.01a8.2 8.2 0 0 1-4.18-1.14l-.3-.18-3.11.82.83-3.04-.2-.31a8.19 8.19 0 0 1-1.26-4.4c0-4.54 3.7-8.24 8.24-8.24 2.2 0 4.27.86 5.83 2.42a8.18 8.18 0 0 1 2.41 5.83c0 4.54-3.7 8.24-8.25 8.24zm4.52-6.17c-.25-.12-1.47-.72-1.7-.81-.23-.08-.39-.12-.56.13-.17.25-.64.81-.78.97-.14.17-.29.19-.53.06-.25-.12-1.05-.39-2-1.23-.74-.66-1.24-1.48-1.39-1.73-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.12-.15.16-.25.25-.42.08-.17.04-.31-.02-.43-.06-.13-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.42-.14-.01-.31-.01-.48-.01-.17 0-.44.06-.67.31-.23.25-.88.86-.88 2.1 0 1.24.9 2.44 1.03 2.61.13.17 1.77 2.71 4.3 3.79.6.26 1.07.42 1.44.53.6.19 1.15.16 1.59.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.08.14-1.18-.06-.11-.23-.17-.48-.29z"/></svg>
              Escríbeme por WhatsApp
            </a>
            <a href={`mailto:${profile.contact.email}`} class="btn-secondary">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              Enviar correo
            </a>
          </div>

          <div class="flex flex-wrap gap-x-6 gap-y-2 text-xs" style="color: var(--dim);">
            <span class="flex items-center gap-1.5">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.1 19.79 19.79 0 0 1 1.61 4.56 2 2 0 0 1 3.6 2.36h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.1 6.1l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              +57 310 750 7846
            </span>
            <span class="flex items-center gap-1.5">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              {profile.location}
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- Servicios / Áreas de práctica -->
    <section id="services" class="relative max-w-5xl mx-auto px-4 md:px-8 pb-20 reveal">
      <div class="section-label"><span class="section-num">01</span> ¿En qué te puedo ayudar?</div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {services.map(service => (
          <div class="edu-card flex flex-col">
            <p class="text-[10px] uppercase tracking-[0.15em] mb-2" style="color: var(--gold);">{service.area}</p>
            <h3 class="text-sm font-semibold mb-2" style="color: var(--text); font-family: var(--serif);">{service.question}</h3>
            <p class="text-xs leading-relaxed mb-4 flex-1" style="color: var(--text-soft);">{service.description}</p>
            <a href={whatsappLink(service.whatsappText)} target="_blank" class="text-xs font-medium inline-flex items-center gap-1.5" style="color: var(--accent);">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.85 9.85 0 0 0 4.73 1.2h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm0 18.15h-.01a8.2 8.2 0 0 1-4.18-1.14l-.3-.18-3.11.82.83-3.04-.2-.31a8.19 8.19 0 0 1-1.26-4.4c0-4.54 3.7-8.24 8.24-8.24 2.2 0 4.27.86 5.83 2.42a8.18 8.18 0 0 1 2.41 5.83c0 4.54-3.7 8.24-8.25 8.24z"/></svg>
              Escríbeme por WhatsApp
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- Cómo trabajo -->
    <section id="how-i-work" class="relative max-w-5xl mx-auto px-4 md:px-8 pb-20 reveal">
      <div class="section-label"><span class="section-num">02</span> Cómo Trabajo</div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {process.map(item => (
          <div class="edu-card">
            <div class="flex items-center justify-center w-7 h-7 rounded-full mb-3 text-xs font-semibold" style="background: var(--gold-soft); color: var(--gold); border: 1px solid var(--gold);">{item.step}</div>
            <h3 class="text-sm font-semibold mb-1" style="color: var(--text); font-family: var(--serif);">{item.title}</h3>
            <p class="text-xs leading-relaxed" style="color: var(--text-soft);">{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Experiencia -->
    <section id="experience" class="relative max-w-5xl mx-auto px-4 md:px-8 pb-20 reveal">
      <div class="section-label"><span class="section-num">03</span> Experiencia Laboral</div>

      <div class="relative pl-8">
        <div class="timeline-line"></div>
        <div class="space-y-10">
          {experience.map((job) => (
            <div class="relative flex gap-6 items-start">
              <div class={`timeline-dot ${job.active ? 'active' : ''}`} style="flex-shrink:0;"></div>
              <div class="exp-card flex-1 min-w-0">
                <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2">
                  <div>
                    <span class="font-semibold text-sm" style="color: var(--text);">{job.role}</span>
                    <span style="color: var(--dim);"> — </span>
                    <span class="text-sm" style="color: var(--accent); font-weight: 500;">{job.company}</span>
                    {job.active && <span class="ml-2 text-[10px] px-1.5 py-0.5 rounded" style="background: var(--gold-soft); color: var(--gold); border: 1px solid var(--gold);">activo</span>}
                  </div>
                  <span class="text-xs shrink-0" style="color: var(--dim);">{job.period}</span>
                </div>

                {job.subPeriods && (
                  <ul class="mb-3 pl-4 space-y-0.5">
                    {job.subPeriods.map(sp => (
                      <li class="text-xs" style="color: var(--dim); list-style: disc;">{sp}</li>
                    ))}
                  </ul>
                )}

                {job.functions && (
                  <p class="text-xs leading-relaxed mb-2" style="color: var(--text-soft);"><strong style="color: var(--text);">Funciones:</strong> {job.functions}</p>
                )}
                <p class="text-xs leading-relaxed mb-3" style="color: var(--text-soft);"><strong style="color: var(--text);">Logros:</strong> {job.achievements}</p>

                <div class="flex flex-wrap gap-1.5">
                  {job.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Educación -->
    <section id="education" class="relative max-w-5xl mx-auto px-4 md:px-8 pb-20 reveal">
      <div class="section-label"><span class="section-num">04</span> Formación Académica</div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
        {education.map(item => (
          <div class="edu-card">
            <h3 class="text-sm font-semibold mb-1" style="color: var(--text); font-family: var(--serif);">{item.title}</h3>
            <p class="text-xs mb-1" style="color: var(--accent);">{item.institution}</p>
            <p class="text-xs" style="color: var(--dim);">{item.year}</p>
          </div>
        ))}
      </div>

      <div class="section-label" style="margin-bottom: 1.5rem; padding-bottom: 10px;"><span class="section-num">—</span> Idiomas</div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {languages.map(lang => (
          <div class="edu-card">
            <h3 class="text-sm font-semibold mb-1" style="color: var(--text); font-family: var(--serif);">{lang.name}</h3>
            <p class="text-xs mb-1" style="color: var(--accent);">{lang.level}</p>
            <p class="text-xs" style="color: var(--dim);">{lang.institution}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Habilidades -->
    <section id="skills" class="relative max-w-5xl mx-auto px-4 md:px-8 pb-24 reveal">
      <div class="section-label"><span class="section-num">05</span> Áreas de Práctica y Habilidades</div>

      <div class="flex flex-wrap gap-2.5">
        {skills.map(skill => <span class="skill-chip">{skill}</span>)}
      </div>
    </section>

    <!-- Contacto -->
    <section id="contact" class="relative max-w-5xl mx-auto px-4 md:px-8 pb-24 reveal">
      <div class="section-label"><span class="section-num">06</span> Contacto</div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <a href={`tel:${profile.contact.phoneIntl}`} class="contact-card block">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5" class="mb-3"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.1 19.79 19.79 0 0 1 1.61 4.56 2 2 0 0 1 3.6 2.36h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.1 6.1l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <div class="text-[10px] uppercase tracking-[0.15em] mb-1" style="color: var(--dim);">Celular</div>
          <div class="text-sm font-medium" style="color: var(--text);">+57 310 750 7846</div>
        </a>

        <a href={profile.contact.whatsapp} target="_blank" class="contact-card block">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--accent)" class="mb-3"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.85 9.85 0 0 0 4.73 1.2h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2z"/></svg>
          <div class="text-[10px] uppercase tracking-[0.15em] mb-1" style="color: var(--dim);">WhatsApp</div>
          <div class="text-sm font-medium" style="color: var(--text);">Escribir mensaje</div>
        </a>

        <a href={`mailto:${profile.contact.email}`} class="contact-card block">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5" class="mb-3"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <div class="text-[10px] uppercase tracking-[0.15em] mb-1" style="color: var(--dim);">Email</div>
          <div class="text-sm font-medium break-all" style="color: var(--text);">{profile.contact.email}</div>
        </a>

        <div class="contact-card">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5" class="mb-3"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <div class="text-[10px] uppercase tracking-[0.15em] mb-1" style="color: var(--dim);">Ubicación</div>
          <div class="text-sm font-medium" style="color: var(--text);">{profile.contact.location}</div>
        </div>
      </div>

      <div class="flex flex-wrap gap-3">
        <a href="/diana-anzola.vcf" download class="btn-secondary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Guardar contacto
        </a>
        <a href="/cv-diana-anzola-tachak.pdf" target="_blank" class="btn-secondary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
          Descargar Hoja de Vida
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="relative max-w-5xl mx-auto px-4 md:px-8 pb-10">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2 text-[11px] pt-6" style="border-top: 1px solid var(--border); color: var(--footer-color);">
        <span>© {new Date().getFullYear()} {profile.name} · Abogada</span>
        <span>Bogotá, Colombia</span>
      </div>
    </footer>

    <!-- WhatsApp flotante -->
    <a href={heroWhatsapp} target="_blank" class="whatsapp-float" aria-label="Escríbeme por WhatsApp">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.85 9.85 0 0 0 4.73 1.2h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm0 18.15h-.01a8.2 8.2 0 0 1-4.18-1.14l-.3-.18-3.11.82.83-3.04-.2-.31a8.19 8.19 0 0 1-1.26-4.4c0-4.54 3.7-8.24 8.24-8.24 2.2 0 4.27.86 5.83 2.42a8.18 8.18 0 0 1 2.41 5.83c0 4.54-3.7 8.24-8.25 8.24zm4.52-6.17c-.25-.12-1.47-.72-1.7-.81-.23-.08-.39-.12-.56.13-.17.25-.64.81-.78.97-.14.17-.29.19-.53.06-.25-.12-1.05-.39-2-1.23-.74-.66-1.24-1.48-1.39-1.73-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.12-.15.16-.25.25-.42.08-.17.04-.31-.02-.43-.06-.13-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.42-.14-.01-.31-.01-.48-.01-.17 0-.44.06-.67.31-.23.25-.88.86-.88 2.1 0 1.24.9 2.44 1.03 2.61.13.17 1.77 2.71 4.3 3.79.6.26 1.07.42 1.44.53.6.19 1.15.16 1.59.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.08.14-1.18-.06-.11-.23-.17-.48-.29z"/></svg>
    </a>
  </div>

  <script>
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    menuToggle && menuToggle.addEventListener('click', () => {
      mobileMenu && mobileMenu.classList.toggle('hidden');
    });
    mobileMenu && mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => mobileMenu.classList.add('hidden'));
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
</Layout>
