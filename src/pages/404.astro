---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Página no encontrada — Diana Anzola Tachak" description="Página no encontrada">
  <div style="min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:1rem; text-align:center; padding: 0 1.5rem;">
    <span style="font-family: var(--serif); font-size:3.5rem; color: var(--accent); font-weight:600;">404</span>
    <p style="color: var(--dim); font-size:0.85rem;">La página que buscas no existe.</p>
    <a href="/" class="btn-secondary" style="margin-top:0.5rem;">Volver al inicio</a>
  </div>
</Layout>
