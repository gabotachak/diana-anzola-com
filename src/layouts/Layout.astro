---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Diana Anzola Tachak — Abogada Laboral en Bogotá",
  description = "Abogada laboral en Bogotá con más de 14 años de experiencia. Tutelas, seguridad social (pensión, EPS, incapacidades), derecho de familia y derecho laboral. Consulta por WhatsApp.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL("/og-image.png", Astro.site).toString();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Attorney",
  "name": "Diana Milena Anzola Tachak",
  "url": "https://diana-anzola.com",
  "image": ogImageURL,
  "email": "abogada@diana-anzola.com",
  "telephone": "+573107507846",
  "jobTitle": "Abogada — Derecho Laboral y Seguridad Social",
  "description": description,
  "priceRange": "Consulta inicial a convenir",
  "areaServed": {
    "@type": "City",
    "name": "Bogotá"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Bogotá",
    "addressCountry": "CO"
  },
  "knowsAbout": [
    "Derecho Laboral",
    "Seguridad Social",
    "Derecho Constitucional",
    "Acciones de Tutela",
    "Contratación Estatal",
    "Derecho Civil",
    "Derecho de Familia"
  ],
  "alumniOf": [
    { "@type": "CollegeOrUniversity", "name": "Universidad Libre de Colombia" },
    { "@type": "CollegeOrUniversity", "name": "Universidad Católica de Colombia" }
  ]
};
---

<!doctype html>
<html lang="es" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Diana Milena Anzola Tachak" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="profile" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageURL} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600;700&display=swap" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      document.documentElement.classList.remove('no-js');
    </script>
  </head>
  <body class="min-h-screen antialiased">
    <slot />
  </body>
</html>
